{
  "name": "freedb",
  "version": "0.1.0",
  "description": "基于 Cloudflare D1 的轻量级自由数据库解决方案",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute freedb --local --file=sql/schema.sql",
    "db:migrate": "wrangler d1 execute freedb --file=sql/migrations",
    "db:seed": "node scripts/seed.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "cloudflare",
    "d1",
    "database",
    "sqlite",
    "serverless",
    "edge"
  ],
  "author": "DarrenHost <darren.host@foxmail.com>",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DarrenHost/freedb.git"
  },
  "bugs": {
    "url": "https://github.com/DarrenHost/freedb/issues"
  },
  "homepage": "https://github.com/DarrenHost/freedb#readme"
}
